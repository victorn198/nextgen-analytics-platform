POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=analytics
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_SCHEMA=raw

PIPELINE_LOAD_MODE=incremental
FAKESTORE_TARGET_CUSTOMERS=10000
FAKESTORE_TARGET_PRODUCTS=2000
FAKESTORE_TARGET_ORDER_LINES=100000
FAKESTORE_INSERT_BATCH_SIZE=5000
FAKESTORE_RANDOM_SEED=42

# Analytics dashboard data source
DASHBOARD_SOURCE_MODE=database
# DATABASE_URL has priority over POSTGRES_* when set
# Example (PostgreSQL): postgresql+psycopg2://postgres:postgres@localhost:5433/analytics
DATABASE_URL=
LOCAL_DATA_DIR=data/local
DASHBOARD_SALES_SCHEMA=marts
DASHBOARD_SALES_TABLE=fct_sales
DASHBOARD_CUSTOMER_SCHEMA=marts
DASHBOARD_CUSTOMER_TABLE=dim_customer
DASHBOARD_PRODUCT_SCHEMA=marts
DASHBOARD_PRODUCT_TABLE=dim_product

# AI analysis (provider-agnostic)
AI_ANALYSIS_ENABLED=true
# Options: huggingface | litellm
AI_PROVIDER=huggingface
AI_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
AI_MAX_NEW_TOKENS=350
AI_TEMPERATURE=0.2

# Hugging Face token (used when AI_PROVIDER=huggingface)
HF_API_TOKEN=

# Backward compatibility (legacy names still supported)
HF_ANALYSIS_ENABLED=true
HF_MODEL_ID=Qwen/Qwen2.5-7B-Instruct
HF_MAX_NEW_TOKENS=350
HF_TEMPERATURE=0.2

# Desktop dashboard security
NEXTGEN_ALLOWED_ORIGINS=http://127.0.0.1:8601,http://localhost:8601
NEXTGEN_ENABLE_AGENT_MUTATIONS=0
NEXTGEN_AGENT_TOKEN=
NEXTGEN_SKIP_PREWARM=0
NEXTGEN_RATE_LIMIT_MAX=120
NEXTGEN_CACHE_TTL_SECONDS=300

# MCP SQL API security
MCP_API_TOKEN=
MCP_STATEMENT_TIMEOUT_MS=10000
MCP_ROW_LIMIT=5000
MCP_ALLOWED_ORIGINS=http://127.0.0.1:8601,http://localhost:8601
